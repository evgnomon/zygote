#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="${ENV_FILE:?ENV_FILE must be set}"

compose() {
  podman-compose --env-file "$ENV_FILE" -f "$SCRIPT_DIR/../deploy/podman/podman-compose.yaml" "$@"
}

load_env() {
  set -a
  source "$ENV_FILE"
  set +a
}

ensure_networks() {
  load_env
  podman network exists "z-${TENANT}" 2>/dev/null || podman network create "z-${TENANT}"
  podman network exists "z-${TENANT}-${NAMESPACE}" 2>/dev/null || podman network create "z-${TENANT}-${NAMESPACE}"
  podman network exists "z-${TENANT}-${NAMESPACE}-${POD}" 2>/dev/null || podman network create "z-${TENANT}-${NAMESPACE}-${POD}"
}

make_volume() {
  load_env
  sudo mkdir -p "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD"
  sudo chown -R "$USER:$USER" "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD"
  mkdir -p "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD/caddy_sites"
}

backup() {
  load_env
  compose pause
  sudo tar -czf "$PLAT_HOME/$TENANT/$NAMESPACE/$POD/caddy_backup.tar.gz" -C "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD" .
  compose unpause
}

restore() {
  load_env
  compose down -v
  sudo rm -rf "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD"
  make_volume
  sudo tar -xpzf "$PLAT_HOME/$TENANT/$NAMESPACE/$POD/caddy_backup.tar.gz" -C "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD"
  compose up -d
}

PLAT_HOME="${PLAT_HOME:-$HOME/.plat}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    up)
      ensure_networks
      make_volume
      compose up -d
      shift
      ;;
    down)
      compose down -v
      shift
      ;;
    destroy)
      load_env
      compose down -v
      sudo rm -rf "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD"
      shift
      ;;
    restart|logs)
      compose "$1"
      shift
      ;;
    backup)
      backup
      shift
      ;;
    restore)
      restore
      shift
      ;;
    *)
      echo "Unknown action: $1"
      exit 1
      ;;
  esac
done
