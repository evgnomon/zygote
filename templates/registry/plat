#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="${ENV_FILE:?ENV_FILE must be set}"

compose() {
  podman-compose --env-file "$ENV_FILE" -f "$SCRIPT_DIR/podman-compose.yaml" "$@"
}

load_env() {
  set -a
  source "$ENV_FILE"
  set +a
}

ensure_networks() {
  load_env
  podman network exists "z-${TENANT}" 2>/dev/null || podman network create "z-${TENANT}"
  podman network exists "z-${TENANT}-${NAMESPACE}" 2>/dev/null || podman network create "z-${TENANT}-${NAMESPACE}"
  podman network exists "z-${TENANT}-${NAMESPACE}-${POD}" 2>/dev/null || podman network create "z-${TENANT}-${NAMESPACE}-${POD}"
}

caddy_sites_dir() {
  echo "/mnt/z/volumes/$TENANT/$NAMESPACE/$CADDY_POD/caddy_sites"
}

register_site() {
  load_env
  local sites_dir
  sites_dir="$(caddy_sites_dir)"
  if [[ -d "$sites_dir" && -n "${DOMAIN:-}" ]]; then
    cat > "$sites_dir/${TENANT}_${NAMESPACE}_${POD}_registry" <<SITE
${DOMAIN} {
  tls internal
  reverse_proxy ${TENANT}_${NAMESPACE}_${POD}_registry:5000
}
SITE
    podman exec "${TENANT}_${NAMESPACE}_${CADDY_POD}_caddy" caddy reload --config /etc/caddy/Caddyfile 2>/dev/null || true
  fi
}

unregister_site() {
  load_env
  local sites_dir
  sites_dir="$(caddy_sites_dir)"
  rm -f "$sites_dir/${TENANT}_${NAMESPACE}_${POD}_registry"
  podman exec "${TENANT}_${NAMESPACE}_${CADDY_POD}_caddy" caddy reload --config /etc/caddy/Caddyfile 2>/dev/null || true
}

htpasswd_file() {
  echo "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD/auth/htpasswd"
}

add_user() {
  load_env
  local user="$1" pass="$2"
  mkdir -p "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD/auth"
  podman run --rm --entrypoint htpasswd docker.io/library/httpd:2 -Bbn "$user" "$pass" >> "$(htpasswd_file)"
}

remove_user() {
  load_env
  local user="$1"
  local hfile
  hfile="$(htpasswd_file)"
  if [[ -f "$hfile" ]]; then
    sed -i "/^${user}:/d" "$hfile"
  else
    echo "htpasswd file not found"
    exit 1
  fi
}

make_volume() {
  load_env
  sudo mkdir -p "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD"
  sudo chown -R "$USER:$USER" "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD"
  mkdir -p "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD/registry_data"
  mkdir -p "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD/auth"
  local uid
  uid="$(podman run --rm --entrypoint "" docker.io/registry:2 id -u)"
  podman unshare chown -R "$uid:$uid" "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD/registry_data"
}

remove_image() {
  load_env
  local image="$1"
  local repo_dir="/mnt/z/volumes/$TENANT/$NAMESPACE/$POD/registry_data/docker/registry/v2/repositories/$image"
  local container="${TENANT}_${NAMESPACE}_${POD}_registry"
  if [[ ! -d "$repo_dir" ]]; then
    echo "Repository '$image' not found"
    exit 1
  fi
  rm -rf "$repo_dir"
  podman exec "$container" bin/registry garbage-collect /etc/docker/registry/config.yml
  podman restart "$container"
  echo "Removed '$image'"
}

remove_tag() {
  load_env
  local ref="$1"
  local image="${ref%%:*}"
  local tag="${ref##*:}"
  if [[ "$image" == "$tag" || -z "$tag" ]]; then
    echo "Usage: $0 remove-tag <repository>:<tag> (e.g. library/redis:latest)"
    exit 1
  fi
  local tag_dir="/mnt/z/volumes/$TENANT/$NAMESPACE/$POD/registry_data/docker/registry/v2/repositories/$image/_manifests/tags/$tag"
  local container="${TENANT}_${NAMESPACE}_${POD}_registry"
  if [[ ! -d "$tag_dir" ]]; then
    echo "Tag '$image:$tag' not found"
    exit 1
  fi
  rm -rf "$tag_dir"
  podman exec "$container" bin/registry garbage-collect /etc/docker/registry/config.yml
  podman restart "$container"
  echo "Removed '$image:$tag'"
}

backup() {
  load_env
  compose pause
  sudo tar -czf "$PLAT_HOME/$TENANT/$NAMESPACE/$POD/registry_backup.tar.gz" -C "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD" .
  compose unpause
}

restore() {
  load_env
  compose down -v
  sudo rm -rf "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD"
  make_volume
  sudo tar -xpzf "$PLAT_HOME/$TENANT/$NAMESPACE/$POD/registry_backup.tar.gz" -C "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD"
  compose up -d
}

PLAT_HOME="${PLAT_HOME:-$HOME/.plat}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    up)
      ensure_networks
      make_volume
      compose up -d
      register_site
      shift
      ;;
    down)
      unregister_site
      compose down -v
      shift
      ;;
    destroy)
      unregister_site
      compose down -v
      rm -rf "/mnt/z/volumes/$TENANT/$NAMESPACE/$POD/registry_data"
      shift
      ;;
    restart|logs)
      compose "$1"
      shift
      ;;
    backup)
      backup
      shift
      ;;
    restore)
      restore
      shift
      ;;
    add-user)
      [[ -z "${2:-}" || -z "${3:-}" ]] && echo "Usage: $0 add-user <username> <password>" && exit 1
      add_user "$2" "$3"
      shift 3
      ;;
    remove-user)
      [[ -z "${2:-}" ]] && echo "Usage: $0 remove-user <username>" && exit 1
      remove_user "$2"
      shift 2
      ;;
    remove-image)
      [[ -z "${2:-}" ]] && echo "Usage: $0 remove-image <repository> (e.g. library/redis)" && exit 1
      remove_image "$2"
      shift 2
      ;;
    remove-tag)
      [[ -z "${2:-}" ]] && echo "Usage: $0 remove-tag <repository>:<tag> (e.g. library/redis:latest)" && exit 1
      remove_tag "$2"
      shift 2
      ;;
    push)
      load_env
      [[ -z "${2:-}" ]] && echo "Usage: $0 push <image> (e.g. library/redis:latest)" && exit 1
      podman push --format=v2s2 "${DOMAIN}:${PORT}/$2"
      shift 2
      ;;
    pull)
      load_env
      [[ -z "${2:-}" ]] && echo "Usage: $0 pull <image> (e.g. library/redis:latest)" && exit 1
      podman pull "${DOMAIN}:${PORT}/$2"
      shift 2
      ;;
    *)
      echo "Unknown action: $1"
      exit 1
      ;;
  esac
done
